@model StudentRecordManagementSystem.Models.Student

<div class="card shadow">

    <div class="card-header bg-primary text-white text-center">
        <h3>
            <i class="bi bi-person-vcard-fill"></i>
            Student Record
        </h3>
    </div>

    <div class="card-body">

        <table class="table table-bordered">

            <tr>
                <th>Roll Number</th>
                <td>@Model.RollNumber</td>
            </tr>

            <tr>
                <th>Name</th>
                <td>@Model.Name</td>
            </tr>

            <tr>
                <th>Maths</th>
                <td>@Model.Maths</td>
            </tr>

            <tr>
                <th>Physics</th>
                <td>@Model.Physics</td>
            </tr>

            <tr>
                <th>Chemistry</th>
                <td>@Model.Chemistry</td>
            </tr>

            <tr>
                <th>English</th>
                <td>@Model.English</td>
            </tr>

            <tr>
                <th>Programming</th>
                <td>@Model.Programming</td>
            </tr>

            <tr class="table-success">
                <th>Total Marks</th>
                <td>@Model.Total</td>
            </tr>

            <tr class="table-primary">
                <th>Average</th>
                <td>@Model.Average.ToString("F2")</td>
            </tr>

            <tr class="table-warning">
                <th>Grade</th>
                <td>@Model.Grade</td>
            </tr>

        </table>

        <div class="text-center">

            <a asp-action="DisplayAll"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left"></i>
                Back

            </a>

        </div>

    </div>

</div>