@model StudentRecordManagementSystem.Models.Student

<div class="card shadow">

    <div class="card-header bg-info text-white text-center">
        <h2>
            <i class="bi bi-mortarboard-fill"></i>
            My Academic Record
        </h2>
    </div>

    <div class="card-body">

        <table class="table table-bordered">

            <tr>
                <th>Roll Number</th>
                <td>@Model.RollNumber</td>
            </tr>

            <tr>
                <th>Name</th>
                <td>@Model.Name</td>
            </tr>

            <tr>
                <th>Maths</th>
                <td>@Model.Maths</td>
            </tr>

            <tr>
                <th>Physics</th>
                <td>@Model.Physics</td>
            </tr>

            <tr>
                <th>Chemistry</th>
                <td>@Model.Chemistry</td>
            </tr>

            <tr>
                <th>English</th>
                <td>@Model.English</td>
            </tr>

            <tr>
                <th>Programming</th>
                <td>@Model.Programming</td>
            </tr>

            <tr class="table-success">
                <th>Total Marks</th>
                <td>@Model.Total</td>
            </tr>

            <tr class="table-primary">
                <th>Average</th>
                <td>@Model.Average.ToString("F2")</td>
            </tr>

            <tr class="table-warning">
                <th>Grade</th>
                <td>@Model.Grade</td>
            </tr>

        </table>

        <div class="text-center">

            <a asp-controller="Account"
               asp-action="Logout"
               class="btn btn-danger">

                <i class="bi bi-box-arrow-right"></i>
                Logout

            </a>

        </div>

    </div>

</div>